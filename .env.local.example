# Supabase (public, safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://bocwkfaldyibtlkhajzy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_1eN5KmU67WUQEy7B63Igwg_AQcEqypG

# Service role (SERVER ONLY — NEVER expose to browser). Get from Supabase dashboard > Project Settings > API.
